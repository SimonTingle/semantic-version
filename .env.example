# --- Site ---
NEXT_PUBLIC_SITE_URL=https://versionlens.example.com

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic (OPTIONAL) ---
# Since v0.2 the deterministic keyword classifier handles non-conventional commits
# in-house. Setting this key only adds an LLM fallback for the small subset of
# commits the classifier flags as low-confidence. Leave blank to disable entirely.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- GitHub (optional; lifts the 60 req/hr unauth limit for the free tier) ---
GITHUB_TOKEN=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_monthly_...
STRIPE_YEARLY_PRICE_ID=price_yearly_...

# --- Quotas ---
FREE_ANON_SCANS=1
FREE_SIGNED_IN_SCANS=2
